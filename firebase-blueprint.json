{
  "entities": {
    "Contact": {
      "title": "Contact Message",
      "description": "Messages sent from the contact form",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the person"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address"
        },
        "phone": {
          "type": "string",
          "description": "Phone number"
        },
        "company": {
          "type": "string",
          "description": "Company name"
        },
        "message": {
          "type": "string",
          "description": "Message content"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the message was sent"
        }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "/contacts/{contactId}": {
      "schema": "Contact",
      "description": "Collection of contact form submissions"
    }
  }
}
